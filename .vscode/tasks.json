{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "deck:dev",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"deck:dev",
				"--",
				"${input:deckName}",
				"--",
				"--remote",
				"--bind",
				"0.0.0.0",
				"-p",
				"3030"
			],
			"isBackground": true,
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "deckName",
			"type": "promptString",
			"description": "Deck name (run 'pnpm run deck:list' to see available decks)"
		}
	]
}