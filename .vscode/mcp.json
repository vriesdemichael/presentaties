{
    "servers": {
        "playwright": {
            "command": "npm",
            "args": [
                "exec",
                "-g",
                "--yes",
                "--",
                "@playwright/mcp@latest",
                "--headless",
                "--isolated",
                "--viewport-size='1920x1080'"
            ]
        },
        "playwright-firefox": {
            "command": "npm",
            "args": [
                "exec",
                "-g",
                "--yes",
                "--",
                "@playwright/mcp@latest",
                "--headless",
                "--isolated",
                "--browser=firefox",
                "--viewport-size='1920x1080'"
            ]
        },
        "playwright-mobile": {
            "command": "npm",
            "args": [
                "exec",
                "-g",
                "--yes",
                "--",
                "@playwright/mcp@latest",
                "--headless",
                "--isolated",
                "--device=iPhone 15"
            ]
        }
    },
    "inputs": []
}